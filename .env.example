# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the React client (for CORS) — change in production
CLIENT_ORIGIN=http://localhost:5173

# ─── Google Sheets ─────────────────────────────────────────────────────────────
# Your Google Sheet ID (from the URL: .../spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Path to your service account credentials JSON file
# Download from Google Cloud Console → IAM → Service Accounts → Keys
# Default: credentials.json in the project root
# GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── Email (Gmail) ─────────────────────────────────────────────────────────────
# Option A: Gmail App Password (simpler)
EMAIL_METHOD=password
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Option B: OAuth2 (more secure, better for production)
# EMAIL_METHOD=oauth2
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_CLIENT_ID=your-client-id
# EMAIL_CLIENT_SECRET=your-client-secret
# EMAIL_REFRESH_TOKEN=your-refresh-token
