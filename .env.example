# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# URL of the React client (for CORS) — change in production
CLIENT_ORIGIN=http://localhost:5173

# ─── Google Sheets (Dutyboard Auto-Sync) ───────────────────────────────────────
# Spreadsheet ID from the dutyboard URL:
#   https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Free Google API key — needed to list sheet tabs automatically.
# Setup (2 minutes):
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or pick an existing one)
#   3. APIs & Services → Enable APIs → search "Google Sheets API" → Enable
#   4. APIs & Services → Credentials → Create Credentials → API Key
#   5. Paste the key here (no OAuth or service account needed)
GOOGLE_API_KEY=your-google-api-key-here

# How often to auto-sync the dutyboard (cron syntax).
# Default: every hour. Examples:
#   "0 * * * *"   — every hour (default)
#   "0 */6 * * *" — every 6 hours
#   "0 2 * * *"   — once daily at 2am
#   "disabled"    — turn off auto-sync (manual only)
SHEETS_SYNC_CRON=0 * * * *

# ─── Email (Gmail) ─────────────────────────────────────────────────────────────
# Option A: Gmail App Password (simpler)
EMAIL_METHOD=password
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Option B: OAuth2 (more secure, better for production)
# EMAIL_METHOD=oauth2
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_CLIENT_ID=your-client-id
# EMAIL_CLIENT_SECRET=your-client-secret
# EMAIL_REFRESH_TOKEN=your-refresh-token
